{%- comment -%}
  Icon snippet — renders SVG icons by name
  Usage: {% render 'icon', icon: 'leather' %}
{%- endcomment -%}

{%- case icon -%}
    {%- when 'leather' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <path d="M20 4c-5 0-10 4-12 9s0 11 4 14c1.5 1.5 3 3 3 5v4h10v-4c0-2 1.5-3.5 3-5 4-3 6-9 4-14s-7-9-12-9z"/>
            <path d="M15 32h10M17 36h6"/>
        </svg>
    {%- when 'travel' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <circle cx="20" cy="20" r="15"/>
            <path d="M20 5v15l9 7"/>
        </svg>
    {%- when 'craft' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <rect x="5" y="5" width="30" height="30" rx="2"/>
            <path d="M8 34l7-14 6 8 6-18 5 24"/>
        </svg>
    {%- when 'decades' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <circle cx="20" cy="20" r="15"/>
            <path d="M20 5v30M5 20h30M10 10l20 20M30 10L10 30"/>
        </svg>
    {%- when 'shipping' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <circle cx="20" cy="20" r="15"/>
            <path d="M12 20h16M20 12v16"/>
        </svg>
    {%- when 'secure' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <rect x="10" y="16" width="20" height="16" rx="2"/>
            <path d="M14 16v-4a6 6 0 0112 0v4"/>
        </svg>
    {%- when 'returns' -%}
        <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="0.8">
            <path d="M8 20a12 12 0 0124 0 12 12 0 01-24 0"/>
            <path d="M8 14v6h6"/>
        </svg>
{%- endcase -%}
