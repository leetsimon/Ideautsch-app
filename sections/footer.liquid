<footer class="footer">
    <div class="footer-inner">
        <div class="footer-grid">
            <div class="footer-brand">
                <a href="/" class="footer-logo">{{ shop.name }}</a>
                <p class="footer-tagline">{{ section.settings.tagline }}</p>
            </div>
            {%- for block in section.blocks -%}
                <div class="footer-col" {{ block.shopify_attributes }}>
                    <h4 class="footer-heading">{{ block.settings.heading }}</h4>
                    <ul class="footer-links">
                        {%- for link in block.settings.menu.links -%}
                            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                        {%- endfor -%}
                    </ul>
                </div>
            {%- endfor -%}
        </div>
        <div class="footer-bottom">
            <p class="footer-copy">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. All rights reserved.</p>
            <div class="footer-social">
                {%- if section.settings.social_instagram != blank -%}
                    <a href="{{ section.settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/></svg>
                    </a>
                {%- endif -%}
                {%- if section.settings.social_pinterest != blank -%}
                    <a href="{{ section.settings.social_pinterest }}" aria-label="Pinterest" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/></svg>
                    </a>
                {%- endif -%}
                {%- if section.settings.social_linkedin != blank -%}
                    <a href="{{ section.settings.social_linkedin }}" aria-label="LinkedIn" target="_blank" rel="noopener">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="3"/><path d="M7 10v7M7 7v.01M11 10v7m0-4c0-2 1.5-3 3-3s3 1 3 3v4"/></svg>
                    </a>
                {%- endif -%}
            </div>
        </div>
    </div>
</footer>

{% schema %}
{
    "name": "Footer",
    "settings": [
        {
            "type": "text",
            "id": "tagline",
            "label": "Tagline",
            "default": "European-crafted leather goods for lives in motion."
        },
        {
            "type": "url",
            "id": "social_instagram",
            "label": "Instagram URL"
        },
        {
            "type": "url",
            "id": "social_pinterest",
            "label": "Pinterest URL"
        },
        {
            "type": "url",
            "id": "social_linkedin",
            "label": "LinkedIn URL"
        }
    ],
    "blocks": [
        {
            "type": "menu_column",
            "name": "Menu Column",
            "settings": [
                {
                    "type": "text",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Collections"
                },
                {
                    "type": "link_list",
                    "id": "menu",
                    "label": "Menu"
                }
            ]
        }
    ],
    "max_blocks": 4
}
{% endschema %}
