<section class="section product-page">
    <div class="container container-narrow">
        <div class="product-layout">
            <!-- Gallery -->
            <div class="product-gallery reveal">
                <div class="product-gallery-main">
                    {%- if product.featured_image != blank -%}
                        <img
                            src="{{ product.featured_image | image_url: width: 900 }}"
                            alt="{{ product.featured_image.alt | escape }}"
                            id="product-main-img">
                    {%- else -%}
                        {{ 'product-1' | placeholder_svg_tag }}
                    {%- endif -%}
                </div>
                {%- if product.images.size > 1 -%}
                    <div class="product-gallery-thumbs">
                        {%- for image in product.images -%}
                            <button class="product-thumb{% if forloop.first %} product-thumb--active{% endif %}"
                                data-src="{{ image | image_url: width: 900 }}"
                                aria-label="View image {{ forloop.index }}">
                                <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}">
                            </button>
                        {%- endfor -%}
                    </div>
                {%- endif -%}
            </div>

            <!-- Product Info -->
            <div class="product-info reveal">
                <p class="product-info-type">{{ product.type }}</p>
                <h1 class="product-info-title">{{ product.title }}</h1>
                <p class="product-info-price">{{ product.price | money }}</p>
                <div class="product-info-desc">{{ product.description }}</div>

                {%- form 'product', product, class: 'product-form' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

                    {%- if product.variants.size > 1 -%}
                        <div class="product-variants">
                            {%- for option in product.options_with_values -%}
                                <div class="product-option">
                                    <label class="product-option-label">{{ option.name }}</label>
                                    <select name="id" class="product-option-select">
                                        {%- for variant in product.variants -%}
                                            <option value="{{ variant.id }}"
                                                {% if variant == product.selected_or_first_available_variant %}selected{% endif %}
                                                {% unless variant.available %}disabled{% endunless %}>
                                                {{ variant.title }} — {{ variant.price | money }}
                                            </option>
                                        {%- endfor -%}
                                    </select>
                                </div>
                            {%- endfor -%}
                        </div>
                    {%- endif -%}

                    <button type="submit" class="product-add-btn"
                        {% unless product.available %}disabled{% endunless %}>
                        {%- if product.available -%}
                            Add to Collection — {{ product.price | money }}
                        {%- else -%}
                            Sold Out
                        {%- endif -%}
                    </button>
                {%- endform -%}

                <!-- Trust -->
                <div class="product-trust">
                    <div class="product-trust-item">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="8" cy="8" r="6"/><path d="M4 8h8M8 4v8"/></svg>
                        <span>Complimentary Express Shipping</span>
                    </div>
                    <div class="product-trust-item">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="8" cy="8" r="6"/><path d="M5 8l2 2 4-4"/></svg>
                        <span>30-Day Returns</span>
                    </div>
                    <div class="product-trust-item">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M8 2l1.5 3 3.5.5-2.5 2.5.6 3.5L8 10l-3.1 1.5.6-3.5L3 5.5 6.5 5z"/></svg>
                        <span>2-Year Craftsmanship Warranty</span>
                    </div>
                </div>

                <!-- Accordion -->
                <div class="accordion">
                    {%- for block in section.blocks -%}
                        <div class="accordion-item" {{ block.shopify_attributes }}>
                            <button class="accordion-trigger" aria-expanded="false">
                                <span>{{ block.settings.title }}</span>
                                <span class="accordion-icon"></span>
                            </button>
                            <div class="accordion-content">
                                <div class="accordion-body">{{ block.settings.content }}</div>
                            </div>
                        </div>
                    {%- endfor -%}
                </div>
            </div>
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Product Page",
    "tag": "section",
    "blocks": [
        {
            "type": "accordion",
            "name": "Accordion Tab",
            "settings": [
                { "type": "text", "id": "title", "label": "Title", "default": "Materials & Craftsmanship" },
                { "type": "richtext", "id": "content", "label": "Content" }
            ]
        }
    ],
    "presets": [{
        "name": "Product Page",
        "blocks": [
            { "type": "accordion", "settings": { "title": "Materials & Craftsmanship", "content": "<p>Full-grain vegetable-tanned Italian leather. Cotton twill lining. Brushed gold-tone hardware. Hand-burnished edges.</p>" } },
            { "type": "accordion", "settings": { "title": "Dimensions", "content": "<p>Height: 33cm. Width: 38cm. Depth: 14cm. Strap drop: 22cm. Weight: 1.1kg. Fits laptop up to 14\".</p>" } },
            { "type": "accordion", "settings": { "title": "Shipping & Delivery", "content": "<p>Complimentary express shipping on orders over $150. USA: 1-3 business days. UK: 1-2 days. Europe: 2-4 days.</p>" } },
            { "type": "accordion", "settings": { "title": "Returns & Warranty", "content": "<p>30-day returns on unworn items. 2-year craftsmanship warranty. Contact care@artyblanc.com.</p>" } }
        ]
    }]
}
{% endschema %}
