<section class="section collection-section" id="collection">
    <div class="container">
        <div class="section-header reveal">
            {%- if section.settings.overline != blank -%}
                <span class="sec-overline">{{ section.settings.overline }}</span>
            {%- endif -%}
            <h2 class="sec-title">{{ section.settings.heading }}</h2>
            {%- if section.settings.subtitle != blank -%}
                <p class="sec-subtitle">{{ section.settings.subtitle }}</p>
            {%- endif -%}
        </div>
        <div class="product-grid">
            {%- for product in collections[section.settings.collection].products limit: section.settings.products_to_show -%}
                <div class="reveal">
                    {% render 'product-card', product: product %}
                </div>
            {%- else -%}
                {%- for i in (1..6) -%}
                    <div class="product-card reveal">
                        <div class="product-card-img">
                            {{ 'product-' | append: i | placeholder_svg_tag: 'product-placeholder' }}
                            <div class="product-card-overlay"><span class="product-card-btn">View Details</span></div>
                        </div>
                        <h3 class="product-card-name">Sample Product {{ i }}</h3>
                        <p class="product-card-cat">Collection</p>
                    </div>
                {%- endfor -%}
            {%- endfor -%}
        </div>
        {%- if section.settings.show_view_all -%}
            <div class="collection-footer reveal">
                <a href="{{ collections[section.settings.collection].url | default: routes.all_products_collection_url }}" class="btn-outline">
                    {{ section.settings.view_all_text | default: 'View All Pieces' }}
                </a>
            </div>
        {%- endif -%}
    </div>
</section>

{% schema %}
{
    "name": "Featured Collection",
    "settings": [
        {
            "type": "text",
            "id": "overline",
            "label": "Overline",
            "default": "The Collection"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Timeless Pieces for Modern Movement"
        },
        {
            "type": "textarea",
            "id": "subtitle",
            "label": "Subtitle",
            "default": "Designed to accompany professionals who navigate between cities, boardrooms, and quiet moments of travel."
        },
        {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
        },
        {
            "type": "range",
            "id": "products_to_show",
            "label": "Products to show",
            "min": 3,
            "max": 12,
            "step": 3,
            "default": 6
        },
        {
            "type": "checkbox",
            "id": "show_view_all",
            "label": "Show 'View All' button",
            "default": true
        },
        {
            "type": "text",
            "id": "view_all_text",
            "label": "View All button text",
            "default": "View All Pieces"
        }
    ],
    "presets": [
        {
            "name": "Featured Collection"
        }
    ]
}
{% endschema %}
