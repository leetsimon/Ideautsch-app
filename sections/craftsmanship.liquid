<section class="section section-sand">
    <div class="container container-narrow">
        <div class="section-header reveal">
            <span class="sec-overline">{{ section.settings.overline }}</span>
            <h2 class="sec-title">{{ section.settings.heading }}</h2>
            {%- if section.settings.subtitle != blank -%}
                <p class="sec-subtitle">{{ section.settings.subtitle }}</p>
            {%- endif -%}
        </div>
        <div class="craft-grid">
            {%- for block in section.blocks -%}
                <div class="craft-item reveal" {{ block.shopify_attributes }}>
                    <span class="craft-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
                    <div>
                        <h3 class="craft-title">{{ block.settings.title }}</h3>
                        <p class="craft-text">{{ block.settings.description }}</p>
                    </div>
                </div>
            {%- endfor -%}
        </div>
    </div>
</section>

{% schema %}
{
    "name": "Craftsmanship",
    "settings": [
        {
            "type": "text",
            "id": "overline",
            "label": "Overline",
            "default": "The Process"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "From Tannery to Atelier"
        },
        {
            "type": "textarea",
            "id": "subtitle",
            "label": "Subtitle",
            "default": "Every piece passes through four stages of meticulous creation before earning our name."
        }
    ],
    "blocks": [
        {
            "type": "step",
            "name": "Process Step",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Title",
                    "default": "Leather Selection"
                },
                {
                    "type": "textarea",
                    "id": "description",
                    "label": "Description",
                    "default": "Only 5% of hides meet our standard. Sourced exclusively from European tanneries with generations of expertise."
                }
            ]
        }
    ],
    "max_blocks": 6,
    "presets": [
        {
            "name": "Craftsmanship",
            "blocks": [
                { "type": "step", "settings": { "title": "Leather Selection", "description": "Only 5% of hides meet our standard. Sourced exclusively from European tanneries with generations of expertise." } },
                { "type": "step", "settings": { "title": "Hand Cutting", "description": "Each panel cut by hand to ensure grain direction and color consistency create unique character." } },
                { "type": "step", "settings": { "title": "Precision Assembly", "description": "Edges burnished, seams reinforced, hardware selected for both function and decades of daily use." } },
                { "type": "step", "settings": { "title": "Final Inspection", "description": "A 27-point quality inspection ensures every detail meets our standard of quiet excellence." } }
            ]
        }
    ]
}
{% endschema %}
